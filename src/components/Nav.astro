---
import { siteConfig } from "../config/site";
// import michelinStars from "../assets/michelin-stars.svg";
---

<header class="site-header">
  <div class="nav-grid">
    <a class="brand" href="#top" aria-label={`${siteConfig.name} home`}>
      <span>{siteConfig.name}</span>
      <!-- <img class="brand-stars" src={michelinStars.src} alt="" width="82" height="40" loading="eager" /> -->
    </a>
    <nav class="nav-links" aria-label="Primary navigation">
      {siteConfig.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="button-link button-link--outline" href="#reserve">
        <span class="ember-dot" aria-hidden="true"></span>
        Book a call
      </a>
    </nav>
    <details class="mobile-nav">
      <summary class="mobile-nav__toggle">Menu</summary>
      <nav class="mobile-nav__panel" aria-label="Mobile navigation">
        {siteConfig.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="button-link" href="#reserve">Reserve</a>
      </nav>
    </details>
  </div>
</header>
