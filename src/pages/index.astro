---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { homeContent } from "../config/home";
import { siteConfig } from "../config/site";
import chefImage from "../assets/chef.webp";
import conceptImage from "../assets/concept.webp";
import detailImage from "../assets/detail.webp";
import heroImage from "../assets/folio.webp";
import interiorImage from "../assets/interior.webp";
import menuImage from "../assets/menu.webp";
import wineImage from "../assets/wine.webp";

const siteUrl = Astro.site ?? new URL("http://localhost:4321");

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Graphic/Web Designer",
  name: siteConfig.name,
  description: siteConfig.description,
  url: new URL(Astro.url.pathname, siteUrl).href,
  image: new URL(siteConfig.defaultImage, siteUrl).href,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  servesCuisine: siteConfig.restaurant.cuisine,
  priceRange: siteConfig.restaurant.priceRange,
  address: {
    "@type": "PostalAddress",
    streetAddress: siteConfig.address.street,
    addressLocality: siteConfig.address.locality,
    postalCode: siteConfig.address.postalCode,
    addressCountry: siteConfig.address.country,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: siteConfig.hours.schema.dayOfWeek,
      opens: siteConfig.hours.schema.opens,
      closes: siteConfig.hours.schema.closes,
    },
  ],
};
---

<BaseLayout image={siteConfig.defaultImage} structuredData={structuredData}>
  <Nav />

  <main id="main">
    <section id="top" class="hero" aria-labelledby="hero-title">
      <Image
        class="media-fill"
        src={heroImage}
        alt="Chef hands finishing a small ceramic plate beside a live wood fire"
        width={667}
        height={1000}
        quality={92}
        loading="eager"
        decoding="sync"
      />
      <div class="overlay" style="background: var(--grad-vignette);"></div>
      <div class="overlay" style="background: var(--grad-veil);"></div>
      <div class="hero-content">
        <div class="hero-grid">
          <div class="hero-heading">
            <p class="label-eyebrow reveal">{homeContent.hero.eyebrow}</p>
            <h1 id="hero-title" class="hero-title display reveal reveal-delay-1">
              {homeContent.hero.title[0]}<br />
              <span class="display-italic" style="color: var(--ember);"
                >{homeContent.hero.title[1]}</span
              ><br />
              {homeContent.hero.title[2]}
            </h1>
          </div>

          <div class="hero-copy reveal reveal-delay-2">
            <p>{homeContent.hero.body}</p>
            <div class="hero-actions">
              <a class="button-link" href="#reserve"
                >{homeContent.hero.action} <span aria-hidden="true">-&gt;</span></a
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="marquee" aria-label="Ombra values">
      <div class="marquee-track">
        {
          [...homeContent.marquee, ...homeContent.marquee].map((item) => (
            <span>
              {item}
              <b aria-hidden="true">*</b>
            </span>
          ))
        }
      </div>
    </section>

    <section id="svg" class="section concept-section">
      <div class="container section-grid">
        <div class="section-kicker">
          <p class="label-eyebrow reveal">{homeContent.concept.eyebrow}</p>
        </div>
        <h2 class="section-heading display reveal">
          {homeContent.concept.heading[0]}<br />
          <span class="display-italic" style="color: var(--ember);">by heat,</span> by hands,<br />
          {homeContent.concept.heading[2]}
        </h2>

        <div class="text-block reveal reveal-delay-1">
          {homeContent.concept.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <figure class="figure-detail reveal">
          <div class="image-frame aspect-3-4">
            <Image
              src={detailImage}
              alt="Handmade ceramic bowl with a small seasonal tasting course"
              width={1200}
              height={1500}
              loading="lazy"
            />
          </div>
          <figcaption class="label-eyebrow" style="margin-top: 1rem;">
            {homeContent.concept.caption}
          </figcaption>
        </figure>

        <div class="fire-block reveal">
          <div class="fire-media image-frame aspect-16-10">
            <Image
              src={conceptImage}
              alt="Glowing embers and flame in a working restaurant hearth"
              width={1400}
              height={875}
              loading="lazy"
            />
          </div>
          <div class="quote-block">
            <blockquote>"{homeContent.concept.quote}"</blockquote>
            <p class="label-eyebrow" style="margin-top: 1.5rem;">
              - {homeContent.concept.quoteByline}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="offer" class="section surface-section">
      <div class="container section-grid">
        <div class="section-kicker">
          <p class="label-eyebrow reveal">{homeContent.tasting.eyebrow}</p>
        </div>
        <h2 class="section-heading display reveal">
          {homeContent.tasting.heading[0]}<br />
          <span class="display-italic" style="color: var(--ember);"
            >{homeContent.tasting.heading[1]}</span
          ><br />
          {homeContent.tasting.heading[2]}
        </h2>

        <aside class="menu-aside reveal" aria-label="Menu notes">
          <div class="image-frame aspect-3-4">
            <Image
              src={menuImage}
              alt="Seasonal ingredients laid out before service on a dark stone prep counter"
              width={1200}
              height={1500}
              loading="lazy"
            />
          </div>
          <p class="label-eyebrow" style="margin-top: 1rem;">{homeContent.tasting.caption}</p>
          <div class="hairline" style="margin-block: 2rem 1.5rem;"></div>
          <p style="color: var(--muted-foreground); line-height: 1.6;">
            {homeContent.tasting.note}
          </p>
        </aside>

        <ol class="course-list">
          {
            homeContent.tasting.courses.map((course) => (
              <li class="course reveal">
                <span class="course-number">{course.number}</span>
                <h3>
                  {course.title}{" "}
                  {course.accent && <span class="display-italic">{course.accent}</span>}
                </h3>
                <p>{course.body}</p>
                <span class="pairing">{course.pairing}</span>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section id="about" class="section">
      <div class="container section-grid">
        <div class="section-kicker">
          <p class="label-eyebrow reveal">{homeContent.chef.eyebrow}</p>
        </div>
        <h2 class="section-heading display reveal">
          {homeContent.chef.heading.line1}<br />
          <span class="display-italic" style="color: var(--ember);"
            >{homeContent.chef.heading.accent}</span
          >
          {homeContent.chef.heading.rest}
        </h2>

        <div class="chef-media image-frame aspect-4-5 reveal">
          <Image
            src={chefImage}
            alt="Black and white candid portrait of Chef Elia Marchetti in profile"
            width={1200}
            height={1500}
            loading="lazy"
          />
        </div>

        <div class="chef-bio reveal reveal-delay-1">
          <p class="chef-quote">
            "{homeContent.chef.quote}"
          </p>
          <div class="hairline" style="margin-block: 2.5rem;"></div>
          <ul class="timeline">
            {
              homeContent.chef.timeline.map((row) => (
                <li>
                  <time datetime={row.year}>{row.year}</time>
                  <span>{row.text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section id="portfolio" class="surface-section">
      <div class="interior-hero">
        <Image
          src={interiorImage}
          alt="Twelve-seat tasting counter with terracotta plaster walls, oak beams, candles, and an open hearth"
          width={1800}
          height={1200}
          loading="lazy"
        />
        <div class="overlay" style="background: var(--grad-veil);"></div>
        <div class="interior-caption">
          <p class="label-eyebrow">{homeContent.interior.eyebrow}</p>
          <h2 class="display">
            {homeContent.interior.heading.lead}
            <span class="display-italic" style="color: var(--ember);"
              >{homeContent.interior.heading.accent}</span
            >
            {homeContent.interior.heading.rest}
          </h2>
        </div>
      </div>

      <div class="container section">
        <div class="feature-grid">
          {
            homeContent.interior.features.map((feature) => (
              <section>
                <p class="label-eyebrow">{feature.title}</p>
                <p>{feature.body}</p>
              </section>
            ))
          }
        </div>
      </div>
    </section>

    <section id="contact" class="section reservation">
      <Image
        class="reservation-bg"
        src={wineImage}
        alt=""
        width={900}
        height={1200}
        loading="lazy"
        aria-hidden="true"
      />
      <div class="overlay" style="background: var(--grad-vignette);"></div>

      <div class="container section-grid">
        <div class="reservation-copy">
          <p class="label-eyebrow reveal">{homeContent.reservation.eyebrow}</p>
          <h2 class="display reveal">
            {homeContent.reservation.heading[0]}<br />
            <span class="display-italic" style="color: var(--ember);"
              >{homeContent.reservation.heading[1]}</span
            ><br />
            {homeContent.reservation.heading[2]}
          </h2>
          <p class="reveal reveal-delay-1">{homeContent.reservation.body}</p>
          <div class="reservation-facts reveal reveal-delay-2">
            <div>
              <p class="label-eyebrow">Service</p>
              <p>{siteConfig.hours.serviceDays}<br />{siteConfig.hours.seatings}</p>
            </div>
            <div>
              <p class="label-eyebrow">Quiet days</p>
              <p>{siteConfig.hours.closed}</p>
            </div>
          </div>
        </div>

        <form
          class="reservation-form reveal"
          action={siteConfig.reservation.formAction}
          method={siteConfig.reservation.method}
          enctype="text/plain"
        >
          <p class="label-eyebrow">{homeContent.reservation.formTitle}</p>
          <div class="form-grid">
            <div class="form-field--full">
              <label class="label-eyebrow" for="name"
                >Full name <span aria-hidden="true">*</span></label
              >
              <input id="name" name="name" autocomplete="name" required />
            </div>
            <div>
              <label class="label-eyebrow" for="email"
                >Email <span aria-hidden="true">*</span></label
              >
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>
            <div>
              <label class="label-eyebrow" for="phone">Phone</label>
              <input id="phone" name="phone" type="tel" autocomplete="tel" />
            </div>
            <div>
              <label class="label-eyebrow" for="date">Date <span aria-hidden="true">*</span></label>
              <input id="date" name="date" type="date" required />
            </div>
            <!-- <div>
              <label class="label-eyebrow" for="guests">Guests</label>
              <select id="guests" name="guests">
                {
                  ["2", "3", "4", "5", "6"].map((option) => (
                    <option value={option}>{option}</option>
                  ))
                }
              </select>
            </div> -->
            <div class="form-field--full">
              <label class="label-eyebrow" for="time">Hour</label>
              <select id="time" name="time">
                {["19:30", "21:45"].map((option) => <option value={option}>{option}</option>)}
              </select>
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="occasion">What I need</label>
              <select id="occasion" name="occasion">
                {
                  ["Logo", "Branding", "Animation", "Illustration", "Website", "Other"].map(
                    (option) => <option value={option}>{option}</option>,
                  )
                }
              </select>
            </div>
            <div class="form-field--full">
              <label class="label-eyebrow" for="note">A note</label>
              <textarea
                id="note"
                name="note"
                rows="3"
                placeholder="Additional details, anything we should know."></textarea>
            </div>
          </div>
          <button class="form-button" type="submit"
            >Send request <span aria-hidden="true">-&gt;</span></button
          >
          <p style="color: var(--muted-foreground); font-size: 0.85rem;">
            {homeContent.reservation.confirmation}
          </p>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
